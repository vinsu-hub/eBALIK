# Copy this file to ".env" and fill in your real values.
# Never commit the real ".env" file to GitHub.

SECRET_KEY=change-this-to-a-random-string

# MySQL
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ebalik_db

# Arduino serial connection
# Leave empty to auto-detect the first CH340 device.
# Windows example: COM3
# Linux example:   /dev/ttyUSB0 or /dev/ttyACM0
# macOS example:   /dev/cu.usbserial-XXXX
SERIAL_PORT=
SERIAL_BAUD=115200
SERIAL_ENABLED=true

# Default loan period (days) used by the manual "Borrow" button on the dashboard
DEFAULT_LOAN_DAYS=7

# Dev-only endpoints (simulate scan, launch terminal/hw-monitor)
# Set to true only during development — disables these endpoints in production
DEBUG_MODE=false
